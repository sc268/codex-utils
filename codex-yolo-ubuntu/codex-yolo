#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODEX_BIN="${CODEX_YOLO_CODEX_BIN:-codex}"
CODEX_YOLO_MODE="${CODEX_YOLO_MODE:-expect}"
CODEX_APPROVAL_POLICY="${CODEX_YOLO_APPROVAL_POLICY:-never}"
CODEX_SANDBOX_MODE="${CODEX_YOLO_SANDBOX_MODE:-danger-full-access}"
CODEX_BYPASS="${CODEX_YOLO_BYPASS_APPROVALS_AND_SANDBOX:-1}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
RUN_POST_STATS=1

print_help() {
  cat <<'EOF'
Usage:
  codex-yolo [codex args...]
  codex-yolo --get-usage [--output-dir DIR] [--machine-name NAME] [--machine-id ID]
  codex-yolo --update-cache-dir [DIR] [--machine-name NAME] [--machine-id ID]
  codex-yolo -h | --help

Behavior:
  Normal Codex sessions use Expect-style automation by default. codex-yolo
  watches Codex approval prompts and automatically sends a, p, or y when those
  approval options are visible. If system expect is unavailable, codex-yolo
  uses the bundled Python pexpect helper.

  Set CODEX_YOLO_MODE=native to use Codex's native bypass flags instead.

Commands:
  --get-usage
      Refresh token usage, print aggregate stats, start the refreshable local
      dashboard, and open it in the browser.

  --update-cache-dir [DIR]
      Same as --get-usage, but with an optional output/cache directory argument.
      Use this for a shared cloud-synced folder.

Options for usage commands:
  --output-dir DIR, --cache-dir DIR
      Directory for index.html, codex-token-usage.csv, codex-token-usage.json,
      and per-computer snapshots. Default: ~/Downloads/codex-token-usage or
      CODEX_TOKEN_USAGE_OUTPUT_DIR.

  --machine-name NAME
      Human-readable computer label in shared reports. Default: hostname or
      CODEX_TOKEN_USAGE_MACHINE_NAME.

  --machine-id ID
      Stable snapshot file ID for this computer. Default: slug of machine name.

Shared folder behavior:
  Each computer writes machines/<machine-id>.json into the output directory.
  index.html totals all snapshots found there and shows per-computer usage.

Environment:
  CODEX_YOLO_CODEX_BIN=/path/to/codex
  CODEX_YOLO_MODE=native|expect
  CODEX_YOLO_APPROVAL_POLICY=never
  CODEX_YOLO_SANDBOX_MODE=danger-full-access
  CODEX_YOLO_BYPASS_APPROVALS_AND_SANDBOX=1|0
  CODEX_YOLO_EDIT_REPLY=a|y
  CODEX_YOLO_COMMAND_REPLY=p|y
  CODEX_YOLO_REPLY=y|a|p
  CODEX_YOLO_SKIP_STATS=1
  CODEX_YOLO_STATS_MODE=async|sync|off
  CODEX_YOLO_STATS_REFRESH=/path/to/refresh-codex-token-usage.command
  CODEX_YOLO_STATS_OPEN=/path/to/open-refreshable-codex-token-usage.command
  CODEX_TOKEN_USAGE_OUTPUT_DIR=/path/to/output
  CODEX_TOKEN_USAGE_MACHINE_NAME="Laptop"
  CODEX_TOKEN_USAGE_MACHINE_ID=laptop

All other arguments are passed through to the Codex CLI. Use codex --help for
Codex's own help.
EOF
}

post_stats_refresh() {
  if [[ -n "${CODEX_YOLO_SKIP_STATS:-}" ]]; then
    return
  fi

  local stats_refresh="${CODEX_YOLO_STATS_REFRESH:-$SCRIPT_DIR/../token-tracker/refresh-codex-token-usage.command}"
  if [[ ! -x "$stats_refresh" ]]; then
    return
  fi

  local mode="${CODEX_YOLO_STATS_MODE:-async}"
  case "$mode" in
    off)
      return
      ;;
    sync)
      "$stats_refresh" >&2 || printf 'codex-yolo: token stats refresh failed\n' >&2
      ;;
    async)
      local output_dir="${CODEX_TOKEN_USAGE_OUTPUT_DIR:-${HOME:-.}/Downloads/codex-token-usage}"
      if ! mkdir -p "$output_dir"; then
        printf 'codex-yolo: token stats refresh not started; cannot create %s\n' "$output_dir" >&2
        return
      fi
      local log_path="$output_dir/codex-yolo-stats-refresh.log"
      local report_url="file://$output_dir/index.html"
      nohup "$stats_refresh" > "$log_path" 2>&1 < /dev/null &
      local refresh_pid=$!
      disown "$refresh_pid" 2>/dev/null || true
      printf 'codex-yolo: token stats refresh started in background, log %s, check %s\n' "$log_path" "$report_url" >&2
      ;;
    *)
      printf 'codex-yolo: unknown CODEX_YOLO_STATS_MODE %s; expected async, sync, or off\n' "$mode" >&2
      ;;
  esac
}

stats_open_path() {
  local bundled_stats_refresh="$SCRIPT_DIR/../token-tracker/refresh-codex-token-usage.command"
  local bundled_stats_open="$SCRIPT_DIR/../token-tracker/open-refreshable-codex-token-usage.command"
  local stats_refresh="${CODEX_YOLO_STATS_REFRESH:-}"
  local stats_open="${CODEX_YOLO_STATS_OPEN:-}"

  if [[ -z "$stats_refresh" && -x "$bundled_stats_refresh" ]]; then
    stats_refresh="$bundled_stats_refresh"
  fi

  if [[ -n "$stats_open" ]]; then
    printf '%s\n' "$stats_open"
  elif [[ -x "$bundled_stats_open" ]]; then
    printf '%s\n' "$bundled_stats_open"
  elif [[ -n "$stats_refresh" ]]; then
    local inferred_stats_open
    inferred_stats_open="$(dirname "$stats_refresh")/open-refreshable-codex-token-usage.command"
    if [[ -x "$inferred_stats_open" ]]; then
      printf '%s\n' "$inferred_stats_open"
    fi
  fi
}

run_usage() {
  local command="$1"
  shift
  local stats_open
  stats_open="$(stats_open_path)"

  if [[ -z "$stats_open" || ! -x "$stats_open" ]]; then
    printf 'codex-yolo: token usage opener not found; set CODEX_YOLO_STATS_OPEN or CODEX_YOLO_STATS_REFRESH\n' >&2
    exit 2
  fi

  local usage_args=()
  if [[ "$command" == "--update-cache-dir" && $# -gt 0 && "$1" != --* ]]; then
    usage_args+=(--output-dir "$1")
    shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --output-dir|--cache-dir|--machine-name|--machine-id|--port)
        if [[ $# -lt 2 ]]; then
          printf 'codex-yolo: %s requires a value\n' "$1" >&2
          exit 2
        fi
        usage_args+=("$1" "$2")
        shift 2
        ;;
      *)
        printf 'codex-yolo: %s cannot be combined with Codex CLI arguments\n' "$command" >&2
        exit 2
        ;;
    esac
  done

  if [[ ${#usage_args[@]} -gt 0 ]]; then
    "$stats_open" "${usage_args[@]}"
  else
    "$stats_open"
  fi
}

run_codex_native() {
  if [[ "$CODEX_BYPASS" != "0" ]]; then
    "$CODEX_BIN" --dangerously-bypass-approvals-and-sandbox "$@"
  else
    "$CODEX_BIN" \
      --ask-for-approval "$CODEX_APPROVAL_POLICY" \
      --sandbox "$CODEX_SANDBOX_MODE" \
      "$@"
  fi
}

run_codex_expect() {
  if command -v expect >/dev/null 2>&1; then
    if [[ ! -r "$SCRIPT_DIR/codex-yolo.expect" ]]; then
      printf 'codex-yolo: expect helper not found at %s\n' "$SCRIPT_DIR/codex-yolo.expect" >&2
      return 2
    fi
    expect "$SCRIPT_DIR/codex-yolo.expect" "$CODEX_BIN" "$@"
    return $?
  fi

  if [[ -r "$SCRIPT_DIR/codex-yolo.pexpect" ]]; then
    "$PYTHON_BIN" "$SCRIPT_DIR/codex-yolo.pexpect" "$CODEX_BIN" "$@"
    return $?
  fi

  printf 'codex-yolo: expect is not installed and pexpect helper is missing\n' >&2
  return 127
}

case "${1:-}" in
  --version|-V|version)
    exec "$CODEX_BIN" "$@"
    ;;
  -h|--help)
    print_help
    exit 0
    ;;
  --get-usage|--update-cache-dir)
    RUN_POST_STATS=0
    usage_command="$1"
    shift
    run_usage "$usage_command" "$@"
    exit 0
    ;;
esac

set +e
case "$CODEX_YOLO_MODE" in
  native)
    run_codex_native "$@"
    ;;
  expect)
    run_codex_expect "$@"
    ;;
  *)
    printf 'codex-yolo: unknown CODEX_YOLO_MODE %s; expected native or expect\n' "$CODEX_YOLO_MODE" >&2
    exit 2
    ;;
esac
codex_exit=$?
set -e

if [[ "$RUN_POST_STATS" == "1" ]]; then
  post_stats_refresh
fi

exit "$codex_exit"
