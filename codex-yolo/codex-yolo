#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export CODEX_YOLO_SCRIPT_DIR="$SCRIPT_DIR"

exec expect -f - -- "$@" <<'EXPECT'

# Run Codex interactively and auto-accept common approval prompts.
#
# Defaults:
#   edits:    "a" = yes, and do not ask again for these files
#   commands: "p" = yes, and do not ask again for this command prefix
#
# Overrides:
#   CODEX_YOLO_EDIT_REPLY=y
#   CODEX_YOLO_COMMAND_REPLY=y
#   CODEX_YOLO_REPLY=y  # legacy shortcut: use y for both
#   CODEX_YOLO_STATS_REFRESH=/path/to/refresh-codex-token-usage.command
#   CODEX_YOLO_STATS_OPEN=/path/to/open-refreshable-codex-token-usage.command
#   CODEX_YOLO_SKIP_STATS=1

set timeout -1

set edit_reply "a"
set command_reply "p"

proc fail {message} {
    puts stderr "codex-yolo: $message"
    exit 2
}

proc print_help {} {
    puts {Usage:
  codex-yolo [codex args...]
  codex-yolo --get-usage [--output-dir DIR] [--machine-name NAME] [--machine-id ID]
  codex-yolo --update-cache-dir [DIR] [--machine-name NAME] [--machine-id ID]
  codex-yolo -h | --help

Commands:
  --get-usage
      Refresh token usage, print aggregate stats, start the refreshable local
      dashboard, and open it in the browser.

  --update-cache-dir [DIR]
      Same as --get-usage, but with an optional output/cache directory argument.
      Use this for a shared cloud-synced folder.

Options for usage commands:
  --output-dir DIR, --cache-dir DIR
      Directory for index.html, codex-token-usage.csv, codex-token-usage.json,
      and per-computer snapshots. Default: ~/Downloads/codex-token-usage or
      CODEX_TOKEN_USAGE_OUTPUT_DIR.

  --machine-name NAME
      Human-readable computer label in shared reports. Default: hostname or
      CODEX_TOKEN_USAGE_MACHINE_NAME.

  --machine-id ID
      Stable snapshot file ID for this computer. Default: slug of machine name.

Shared folder behavior:
  Each computer writes machines/<machine-id>.json into the output directory.
  index.html totals all snapshots found there and shows per-computer usage.

Environment:
  CODEX_YOLO_EDIT_REPLY=y|a
  CODEX_YOLO_COMMAND_REPLY=y|p
  CODEX_YOLO_REPLY=y|a|p
  CODEX_YOLO_SKIP_STATS=1
  CODEX_YOLO_STATS_REFRESH=/path/to/refresh-codex-token-usage.command
  CODEX_YOLO_STATS_OPEN=/path/to/open-refreshable-codex-token-usage.command
  CODEX_TOKEN_USAGE_OUTPUT_DIR=/path/to/output
  CODEX_TOKEN_USAGE_MACHINE_NAME="Laptop"
  CODEX_TOKEN_USAGE_MACHINE_ID=laptop

All other arguments are passed through to the Codex CLI. Use codex --help for
Codex's own help.}
}

proc run_usage {stats_open usage_args} {
    if {$stats_open eq "" || ![file executable $stats_open]} {
        fail "token usage opener not found; set CODEX_YOLO_STATS_OPEN or CODEX_YOLO_STATS_REFRESH"
    }

    set usage_command [list $stats_open]
    foreach item $usage_args {
        lappend usage_command $item
    }

    if {[catch {exec {*}$usage_command 2>@1} usage_output]} {
        puts stderr "codex-yolo: token usage refresh failed: $usage_output"
        exit 1
    }
    if {$usage_output ne ""} {
        puts $usage_output
    }
    exit 0
}

proc usage_args_from_args {command args_list} {
    set usage_args [list]
    set remaining $args_list

    if {$command eq "--update-cache-dir" && [llength $remaining] > 0} {
        set first [lindex $remaining 0]
        if {![string match "--*" $first]} {
            lappend usage_args "--output-dir" [file normalize $first]
            set remaining [lrange $remaining 1 end]
        }
    }

    while {[llength $remaining] > 0} {
        set option [lindex $remaining 0]
        switch -- $option {
            --output-dir -
            --cache-dir {
                if {[llength $remaining] < 2} {
                    fail "$option requires a directory"
                }
                lappend usage_args "--output-dir" [file normalize [lindex $remaining 1]]
                set remaining [lrange $remaining 2 end]
            }
            --machine-name -
            --machine-id {
                if {[llength $remaining] < 2} {
                    fail "$option requires a value"
                }
                lappend usage_args $option [lindex $remaining 1]
                set remaining [lrange $remaining 2 end]
            }
            --port {
                if {[llength $remaining] < 2} {
                    fail "$option requires a port"
                }
                lappend usage_args $option [lindex $remaining 1]
                set remaining [lrange $remaining 2 end]
            }
            default {
                fail "$command cannot be combined with Codex CLI arguments"
            }
        }
    }

    return $usage_args
}

if {[llength $argv] > 0} {
    set first_arg [lindex $argv 0]
    if {$first_arg eq "-h" || $first_arg eq "--help"} {
        print_help
        exit 0
    }
}

if {[info exists env(CODEX_YOLO_REPLY)]} {
    switch -- $env(CODEX_YOLO_REPLY) {
        y {
            set edit_reply "y"
            set command_reply "y"
        }
        a {
            set edit_reply "a"
        }
        p {
            set command_reply "p"
        }
        default {
            fail "CODEX_YOLO_REPLY must be one of: y, a, p"
        }
    }
}

if {[info exists env(CODEX_YOLO_EDIT_REPLY)]} {
    set edit_reply $env(CODEX_YOLO_EDIT_REPLY)
}

if {[info exists env(CODEX_YOLO_COMMAND_REPLY)]} {
    set command_reply $env(CODEX_YOLO_COMMAND_REPLY)
}

if {$edit_reply ne "a" && $edit_reply ne "y"} {
    fail "CODEX_YOLO_EDIT_REPLY must be either 'a' or 'y'"
}

if {$command_reply ne "p" && $command_reply ne "y"} {
    fail "CODEX_YOLO_COMMAND_REPLY must be either 'p' or 'y'"
}

set script_dir $env(CODEX_YOLO_SCRIPT_DIR)
set bundled_stats_refresh [file normalize [file join $script_dir .. token-tracker refresh-codex-token-usage.command]]
set bundled_stats_open [file normalize [file join $script_dir .. token-tracker open-refreshable-codex-token-usage.command]]
set stats_refresh ""
set stats_open ""

if {[info exists env(CODEX_YOLO_STATS_REFRESH)]} {
    set stats_refresh $env(CODEX_YOLO_STATS_REFRESH)
} elseif {[file executable $bundled_stats_refresh]} {
    set stats_refresh $bundled_stats_refresh
}

if {[info exists env(CODEX_YOLO_STATS_OPEN)]} {
    set stats_open $env(CODEX_YOLO_STATS_OPEN)
} elseif {[file executable $bundled_stats_open]} {
    set stats_open $bundled_stats_open
} elseif {$stats_refresh ne ""} {
    set inferred_stats_open [file join [file dirname $stats_refresh] open-refreshable-codex-token-usage.command]
    if {[file executable $inferred_stats_open]} {
        set stats_open $inferred_stats_open
    }
}

if {[llength $argv] > 0} {
    set command [lindex $argv 0]
    if {$command eq "--get-usage" || $command eq "--update-cache-dir"} {
        set usage_args [usage_args_from_args $command [lrange $argv 1 end]]
        run_usage $stats_open $usage_args
    }
}

spawn -noecho codex {*}$argv

set edit_prompt {Would you like to make the following edits\?}
set command_prefix_prompt {Yes, and don't ask again for commands that start}

if {[catch {
    interact -o \
        -re $edit_prompt {
            after 100
            send -- "$edit_reply\r"
        } \
        -re $command_prefix_prompt {
            after 100
            send -- "$command_reply\r"
        } \
        eof {
        }
} interact_error]} {
    if {![string match "*spawn id*not open*" $interact_error]} {
        puts stderr "codex-yolo: interact ended: $interact_error"
    }
}

set codex_exit 0
if {[catch {wait} wait_result]} {
    set codex_exit 1
} elseif {[llength $wait_result] >= 4} {
    set os_error [lindex $wait_result 2]
    set status_value [lindex $wait_result 3]
    if {$os_error == 0} {
        set codex_exit $status_value
    } else {
        set codex_exit 1
    }
}

if {![info exists env(CODEX_YOLO_SKIP_STATS)] && $stats_refresh ne "" && [file executable $stats_refresh]} {
    if {[catch {exec $stats_refresh 2>@1} stats_output]} {
        puts stderr "codex-yolo: token stats refresh failed: $stats_output"
    } elseif {$stats_output ne ""} {
        puts stderr $stats_output
    }
}

exit $codex_exit
EXPECT
